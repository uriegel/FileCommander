<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FileCommander.Controls.ColumnViewHeader.ColumnViewHeaders"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:headers="using:FileCommander.Controls.ColumnViewHeader"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ItemsControl x:Name="Headers" >
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Grid.Column="{Binding Index}" >
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </Border.Style>
                    <Grid Margin="5, 0" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" TextAlignment="{Binding Alignment}" Opacity="0.8" />
                        <!--<TextBlock Grid.Column="0" Text="{Binding SortType, Converter={StaticResource SortTypeConverter}}" TextAlignment="Center" Opacity="0.8"></TextBlock>-->
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
        <ItemsControl.ItemContainerStyle>
            <Style TargetType="Border">
                <Setter Property="Grid.Column" Value="{Binding Index}" />
            </Style>
        </ItemsControl.ItemContainerStyle>

        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <Grid Name="ColumnViewHeaderGrid" headers:ColumnViewHeaders.Columns="{Binding}">
                </Grid>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

    </ItemsControl>
</UserControl>
