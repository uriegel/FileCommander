<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="using:FileCommander.ValueConverter"
    xmlns:controls="using:FileCommander.Controls">

    <DataTemplate x:Key="ParentItemDataTemplate">
        <controls:ItemGrid>
            <Grid Margin="2, 0, 5, 0"  >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!--<Image Source="/Assets/Folder.png" Width="16" Height="16" Margin="0,0,5,0"/>-->
                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="5,0" />
            </Grid>
        </controls:ItemGrid>
    </DataTemplate>
</ResourceDictionary>