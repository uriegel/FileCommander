<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="using:FileCommander.ValueConverter"
    xmlns:controls="using:FileCommander.Controls">

    <converter:IconImageConverter x:Key="IconImageConverter" />

    <DataTemplate x:Key="FileItemDataTemplate">
        <controls:ItemGrid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Grid Margin="2, 0, 5, 0"  >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <Image Source="{Binding IconIndex, Converter={StaticResource IconImageConverter}}" Width="16" Height="16" Margin="0,0,5,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Grid>
            <!--<TextBlock Margin="0, 0, 5, 0" Grid.Column="1" Text="{Binding Name}" />-->
            <TextBlock Margin="5, 0, 0, 0" Grid.Column="1" TextAlignment="Right" TextTrimming="CharacterEllipsis"
                            Text="{Binding Size}" />
        </controls:ItemGrid>
    </DataTemplate>
</ResourceDictionary>